# ─────────────────────────────────────────────────────────────────────
# WorkspaceLauncher .gitignore
# Stack: Electron + Vite + React + Node.js
# ─────────────────────────────────────────────────────────────────────

# ── Node.js ──────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── C# / .NET (Workspace Launcher) ──────────────────────────────────
WorkspaceLauncher/bin/
WorkspaceLauncher/obj/
WorkspaceLauncher/publish/
WorkspaceLauncher/frontend/dist/
WorkspaceLauncher/frontend/node_modules/
*.dll
*.pdb
*.user
*.suo
*.cache
*.nupkg
*.snupkg
*.WebView2/
debug.log
publish/


# ── Python (legacy script) ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/

# ── Environment / Secrets ────────────────────────────────────────────
.env
.env.local
.env.*.local
*.local

# ── IDE / Editor ─────────────────────────────────────────────────────
.vs/
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath

# ── OS Generated ────────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ── Runtime / Cache ─────────────────────────────────────────────────
*.log
.eslintcache
.parcel-cache/
.cache/
*.tsbuildinfo

# ── Personal config (don't track user-specific paths) ───────────────
mis_apps_config*.json
error.txt