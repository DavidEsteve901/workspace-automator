<Window x:Class="WorkspaceLauncher.Core.CustomZoneEngine.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zone Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewKeyDown="Window_PreviewKeyDown"
        ShowInTaskbar="False">
    <Grid x:Name="RootGrid">
        <Canvas x:Name="OverlayCanvas" />
        
        <!-- Message for unconfigured monitors -->
        <Border x:Name="NoLayoutMessage" 
                Visibility="Collapsed" 
                Background="#D0101012" 
                CornerRadius="12" 
                Padding="40,20"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="⚠ No hay layout asignado en este escritorio" 
                           Foreground="White" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" />
                <TextBlock Text="Usa Ctrl + L o el Administrador para asignar uno" 
                           Foreground="White" 
                           FontSize="14" 
                           Opacity="0.8" 
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
