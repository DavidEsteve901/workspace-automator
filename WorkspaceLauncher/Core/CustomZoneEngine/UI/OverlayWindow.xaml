<Window x:Class="WorkspaceLauncher.Core.CustomZoneEngine.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zone Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewKeyDown="Window_PreviewKeyDown"
        ShowInTaskbar="False">
    <Grid x:Name="RootGrid">
        <Canvas x:Name="OverlayCanvas" />

        <!-- No-layout message: premium glassmorphism panel -->
        <Border x:Name="NoLayoutMessage"
                Visibility="Collapsed"
                CornerRadius="18"
                Padding="56,28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderThickness="1">
            <Border.Background>
                <SolidColorBrush Color="#CC0A0A0D" />
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#33FFFFFF" />
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect BlurRadius="48" ShadowDepth="0" Opacity="0.75" Color="#000000"/>
            </Border.Effect>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <TextBlock x:Name="NoLayoutIcon"
                           Text="⚠"
                           FontSize="38"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,14">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="#FFEA00"/>
                    </TextBlock.Foreground>
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.9" Color="#FFEA00"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Sin diseño asignado en este escritorio"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <TextBlock Text="Usa el Gestor de Layouts para asignar uno"
                           FontSize="13"
                           Opacity="0.5"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           TextAlignment="Center">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="#FFFFFF"/>
                    </TextBlock.Foreground>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
