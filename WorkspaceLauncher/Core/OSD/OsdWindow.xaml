<Window x:Class="WorkspaceLauncher.Core.OSD.OsdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        Width="340" SizeToContent="Height"
        WindowStartupLocation="Manual"
        Opacity="0">
  <Border Background="#CC1a1a2e" CornerRadius="10" Padding="18,12"
          BorderBrush="#7c3aed" BorderThickness="1">
    <TextBlock x:Name="MessageText"
               Foreground="#e2e8f0"
               FontSize="14"
               FontFamily="Segoe UI"
               TextWrapping="Wrap"
               MaxWidth="300" />
  </Border>
</Window>
